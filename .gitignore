# Dependency directories
**/node_modules/
**/jspm_packages/
**/web_modules/

# Lock files (platform-specific, causes issues on Railway Linux builds)
backend/package-lock.json

# Build outputs
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/
**/.cache/

# Environment files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.env
**/*.env.*

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Database (Prisma / SQLite)
**/prisma/*.db
**/prisma/*.db-journal
**/prisma/dev.db
**/prisma/dev.db-journal

# Operating system files
**/.DS_Store
**/Thumbs.db

# IDEs and editors
**/.idea/
**/.vscode/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln
**/*.sw?
